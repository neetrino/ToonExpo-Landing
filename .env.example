# Auth.js (min 32 chars)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# Seed admin (pnpm db:seed)
SEED_ADMIN_EMAIL="admin@toonexpo.local"
SEED_ADMIN_PASSWORD="change-me-in-production"
# true = удалить все проекты и заново импортировать docs/data/ToonExpoData2026.csv
SEED_REPLACE_PROJECTS=""

# Cloudflare R2 (optional — upload)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Optional: next/image — extra HTTPS hostnames (comma-separated), if gallery URLs
# are served from a CDN other than R2_PUBLIC_URL
NEXT_PUBLIC_EXTRA_IMAGE_HOSTNAMES=""

# Optional: HSTS on all responses — only if the site is always served over HTTPS
SECURITY_ENABLE_HSTS=""
